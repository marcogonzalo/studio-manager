{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.veta.pro" }],
      "destination": "https://veta.pro/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "www.veta.pro" }],
      "destination": "https://veta.pro/:path+",
      "permanent": true
    }
  ]
}
